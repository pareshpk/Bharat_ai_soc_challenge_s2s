<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- BhashaBridge tricolour title — set by code -->
        <ImageView
            android:id="@+id/setupTitle"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/logo_bhashabridge"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp"
            android:contentDescription="BhashaBridge" />

    <!-- Bilingual subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Offline Speech Translation"
        android:textColor="#3A3A3A"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.06"
        android:layout_marginBottom="64dp" />

    <!-- Choose language prompt — shown in both languages -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose your language"
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="अपनी भाषा चुनें"
        android:textColor="#666666"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="40dp" />

    <!-- Language buttons side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2">

        <Button
            android:id="@+id/btnEnglish"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="English"
            android:textColor="#0D0D0D"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_translate_btn" />

        <Button
            android:id="@+id/btnHindi"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="हिंदी"
            android:textColor="#0D0D0D"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_translate_btn" />

    </LinearLayout>

    <!-- Small note -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You can change this later in settings\nआप इसे बाद में सेटिंग में बदल सकते हैं"
        android:textColor="#444444"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="24dp" />

</LinearLayout>
