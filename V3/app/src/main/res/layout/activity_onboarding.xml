<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:gravity="center"
    android:padding="32dp">

        <ImageView
            android:id="@+id/onboardingTitle"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/logo_bhashabridge"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp"
            android:contentDescription="BhashaBridge" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Offline Speech Translation"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"/>

    <!-- Step 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="28dp">
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🎤"
            android:textSize="28sp"
            android:gravity="center"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speak in English or Hindi"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF9933"
                android:textSize="13sp"
                android:text="अंग्रेज़ी या हिंदी में बोलें"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap the mic and speak naturally"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Step 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="28dp">
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="⚡"
            android:textSize="28sp"
            android:gravity="center"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instant offline translation"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF9933"
                android:textSize="13sp"
                android:text="तुरंत ऑफ़लाइन अनुवाद"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Works without internet, anywhere"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Step 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="48dp">
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🆘"
            android:textSize="28sp"
            android:gravity="center"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency phrases ready"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF9933"
                android:textSize="13sp"
                android:text="आपातकालीन वाक्य तैयार"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical, safety and location phrases one tap away"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Get Started →"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0D0D0D"
        android:backgroundTint="#6EE7B7"/>

</LinearLayout>
