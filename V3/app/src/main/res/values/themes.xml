<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PipelineClean" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Background -->
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>

        <!-- Status bar — pure black, light icons -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Accent / primary colours -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_pressed</item>
        <item name="colorOnPrimary">@color/accent_on</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/accent_on</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorControlHighlight">#206EE7B7</item>

        <!-- EditText cursor and handles -->
        <item name="android:textColorHighlight">#406EE7B7</item>
        <item name="colorControlActivated">@color/accent</item>

        <!-- Ripple on dark -->
        <item name="rippleColor">@color/accent_dim</item>
    </style>
</resources>
